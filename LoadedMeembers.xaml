<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Group.LoadedMeembers"
             xmlns:local="clr-namespace:Group.Models"
             Title="Участники"
             BackgroundColor="#0D0D0D">

    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="16">

            <!-- Заголовок страницы -->
            <VerticalStackLayout Spacing="6" Margin="0,0,0,8">
                <Label Text="УЧАСТНИКИ ГРУППЫ" 
                       TextColor="#8E8E93" 
                       FontSize="13" 
                       FontAttributes="Bold"
                       CharacterSpacing="2"/>

                <!-- Информация о количестве участников -->
                <HorizontalStackLayout Spacing="6">
                    <Label Text="Всего участников:" 
                           TextColor="#636366" 
                           FontSize="13"/>
                    <Label Text="{Binding Members.Count}" 
                           TextColor="#0A84FF" 
                           FontSize="13" 
                           FontAttributes="Bold"/>
                </HorizontalStackLayout>

                <!-- Разделитель -->
                <BoxView HeightRequest="1" BackgroundColor="#2C2C2E" Margin="0,8"/>
            </VerticalStackLayout>

            <!-- Список участников -->
            <CollectionView ItemsSource="{Binding Members}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="local:User">

                        <!-- Карточка участника -->
                        <Frame BackgroundColor="#1C1C1E" 
                               CornerRadius="20" 
                               Padding="16" 
                               Margin="0,0,0,12"
                               HasShadow="True"
                               BorderColor="#2C2C2E">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Аватар участника -->
                                <Frame Grid.Column="0"
                                       CornerRadius="28" 
                                       HeightRequest="56" 
                                       WidthRequest="56" 
                                       Padding="0" 
                                       BackgroundColor="#5E5CE6" 
                                       BorderColor="Transparent">
                                    <Label Text="{Binding Name, StringFormat='{}{0:0:1}', FallbackValue='U'}" 
                                           TextColor="White" 
                                           FontSize="24" 
                                           FontAttributes="Bold"
                                           HorizontalOptions="Center" 
                                           VerticalOptions="Center"/>
                                </Frame>

                                <!-- Информация об участнике -->
                                <VerticalStackLayout Grid.Column="1" 
                                                     Spacing="4" 
                                                     VerticalOptions="Center" 
                                                     Margin="15,0,10,0">

                                    <!-- Имя участника -->
                                    <Label Text="{Binding Name, FallbackValue='Имя участника'}" 
                                           TextColor="White" 
                                           FontSize="18" 
                                           FontAttributes="Bold"
                                           LineBreakMode="TailTruncation"/>

                                    <!-- ID участника -->
                                    <HorizontalStackLayout Spacing="6">
                                        <Label Text="ID:" 
                                               TextColor="#8E8E93" 
                                               FontSize="12"/>
                                        <Label Text="{Binding Id, StringFormat='#{0}', FallbackValue='#12345'}" 
                                               TextColor="#0A84FF" 
                                               FontSize="12"
                                               FontFamily="Menlo"/>
                                    </HorizontalStackLayout>

                                    <!-- Роль участника (если есть) -->
                                    <HorizontalStackLayout Spacing="6" 
                                                           IsVisible="{Binding Role, Converter={StaticResource IsNotNullOrEmptyConverter}}">
                                      
                                        <Label Text="{Binding Role, FallbackValue='Участник'}" 
                                               TextColor="#FF9F0A" 
                                               FontSize="12"
                                               FontAttributes="Bold"/>
                                    </HorizontalStackLayout>

                                </VerticalStackLayout>

                                <!-- Кнопка удаления -->
                                <Button Grid.Column="2"
                                        Text="🗑️"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteMemberCommand}"
                                        CommandParameter="{Binding .}"
                                        Background="#FF453A" 
                                        TextColor="White"
                                        FontSize="18"
                                        WidthRequest="50"
                                        HeightRequest="50"
                                        CornerRadius="25"
                                        VerticalOptions="Center"
                                        HorizontalOptions="Center">
                                    <Button.Shadow>
                                        <Shadow Brush="#FF453A" 
                                                Offset="0,3" 
                                                Radius="8" 
                                                Opacity="0.4"/>
                                    </Button.Shadow>
                                </Button>

                            </Grid>

                        </Frame>

                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Сообщение, если участников нет -->
           

            <!-- Кнопка приглашения (всегда видна, если есть участники) -->
            

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>