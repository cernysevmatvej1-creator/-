<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Group.MainPage"
             Title="Главная"
             BackgroundColor="#0D0D0D">

    <Grid>
        <ScrollView>
            <VerticalStackLayout Spacing="24" Padding="24" VerticalOptions="Center">

                <!-- Заголовок с приветствием -->
                <VerticalStackLayout Spacing="8" Margin="0,0,0,10">

                    <!-- Аватар пользователя -->
                 

                    <!-- Приветствие -->
                    <Label Text="ДОБРО ПОЖАЛОВАТЬ" 
                           TextColor="#8E8E93" 
                           FontSize="12" 
                           FontAttributes="Bold"
                           CharacterSpacing="2"
                           HorizontalTextAlignment="Center"/>

                    <Label Text="{Binding Nik, FallbackValue='Гость'}" 
                           TextColor="White" 
                           FontSize="28" 
                           FontAttributes="Bold"
                           HorizontalTextAlignment="Center"
                           LineBreakMode="TailTruncation"/>

                </VerticalStackLayout>

                <!-- Карточка с настройками профиля -->
                <Frame BackgroundColor="#1C1C1E" 
                       CornerRadius="20" 
                       Padding="24" 
                       HasShadow="True"
                       BorderColor="#2C2C2E">

                    <VerticalStackLayout Spacing="20">

                        <!-- Заголовок секции -->
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="👤" FontSize="16"/>
                            <Label Text="НАСТРОЙКИ ПРОФИЛЯ" 
                                   TextColor="#8E8E93" 
                                   FontSize="13" 
                                   FontAttributes="Bold"
                                   CharacterSpacing="1.5"/>
                        </HorizontalStackLayout>

                        <!-- Поле ввода ника -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="ВАШ НИКНЕЙМ" 
                                   TextColor="#8E8E93" 
                                   FontSize="11" 
                                   CharacterSpacing="1.2"/>

                            <Frame BackgroundColor="#2C2C2E" 
                                   CornerRadius="12" 
                                   Padding="15,5" 
                                   BorderColor="#3A3A3C"
                                   HasShadow="False">
                                <Entry Placeholder="Введите ваш ник" 
                                       PlaceholderColor="#636366"
                                       Text="{Binding Nik}" 
                                       TextColor="White"
                                       FontSize="16"
                                       BackgroundColor="Transparent"/>
                            </Frame>
                        </VerticalStackLayout>

                        <!-- Текущий ник -->
                        <HorizontalStackLayout Spacing="6" HorizontalOptions="Center">
                            <Label Text="Текущий ник:" 
                                   TextColor="#8E8E93" 
                                   FontSize="12"/>
                            <Label Text="{Binding Nik, FallbackValue='Не установлен'}" 
                                   TextColor="#0A84FF" 
                                   FontSize="12" 
                                   FontAttributes="Bold"/>
                        </HorizontalStackLayout>

                        <!-- Разделитель -->
                        <BoxView HeightRequest="1" BackgroundColor="#2C2C2E" Margin="0,5"/>

                        <!-- Информация о приложении -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="ИНФОРМАЦИЯ" 
                                   TextColor="#8E8E93" 
                                   FontSize="11" 
                                   CharacterSpacing="1.2"/>


                            <HorizontalStackLayout Spacing="10">
                                <Label Text="🆔" FontSize="14"/>
                                <Label Text="{Binding Id}" 
                                       TextColor="#E5E5EA" 
                                       FontSize="13"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>

                    </VerticalStackLayout>

                </Frame>

                <!-- Кнопка сохранения -->
                <Button Text="СОХРАНИТЬ ИЗМЕНЕНИЯ" 
                        Command="{Binding SaveNikCommand}" 
                        Background="#30D158" 
                        TextColor="White"
                        FontSize="15"
                        FontAttributes="Bold"
                        CharacterSpacing="1"
                        CornerRadius="14"
                        HeightRequest="55"
                        Margin="0,10,0,0">
                    <Button.Shadow>
                        <Shadow Brush="#30D158" 
                                Offset="0,4" 
                                Radius="12" 
                                Opacity="0.4"/>
                    </Button.Shadow>
                </Button>

                <!-- Дополнительная информация -->
                <Label Text="Изменения вступят в силу после сохранения" 
                       TextColor="#636366" 
                       FontSize="12" 
                       HorizontalTextAlignment="Center"
                       Margin="0,10,0,0"/>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Индикатор загрузки (если нужно) -->
        <ActivityIndicator IsVisible="{Binding IsLoading}" 
                           IsRunning="{Binding IsLoading}" 
                           Color="#0A84FF" 
                           HeightRequest="50" 
                           WidthRequest="50"
                           VerticalOptions="Center" 
                           HorizontalOptions="Center"/>

    </Grid>
</ContentPage>