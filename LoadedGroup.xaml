<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Group.Models"
             x:Class="Group.LoadedGroup"
             Title="Мои группы"
             BackgroundColor="#0D0D0D">

    <Grid>
        <ScrollView>
            <VerticalStackLayout Spacing="16" Padding="16">

                <VerticalStackLayout Spacing="6" Margin="0,0,0,8">
                    <Label Text="МОИ ГРУППЫ"
                           TextColor="#8E8E93"
                           FontSize="13"
                           FontAttributes="Bold"
                           CharacterSpacing="2"/>
                    <HorizontalStackLayout Spacing="6">
                        <Label Text="Всего групп:" TextColor="#636366" FontSize="13"/>
                        <Label Text="{Binding Groups.Count}"
                               TextColor="#0A84FF"
                               FontSize="13"
                               FontAttributes="Bold"/>
                    </HorizontalStackLayout>
                    <BoxView HeightRequest="1" BackgroundColor="#2C2C2E" Margin="0,8"/>
                </VerticalStackLayout>

                <CollectionView ItemsSource="{Binding Groups}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="local:NewGroupModel">
                            <Frame BackgroundColor="#1C1C1E"
                                   CornerRadius="20"
                                   Padding="20"
                                   Margin="0,0,0,16"
                                   HasShadow="True"
                                   BorderColor="#2C2C2E">
                                <VerticalStackLayout Spacing="16">

                                    <HorizontalStackLayout Spacing="15">

                                        <!-- ИСПРАВЛЕНО: FirstCharConverter вместо кривого StringFormat -->
                                        <Frame CornerRadius="28"
                                               HeightRequest="60"
                                               WidthRequest="60"
                                               Padding="0"
                                               BackgroundColor="#BF5AF2"
                                               BorderColor="Transparent">
                                            <Label Text="{Binding NikAvtor,
                                                           Converter={StaticResource FirstCharConverter},
                                                           FallbackValue='G'}"
                                                   TextColor="White"
                                                   FontSize="26"
                                                   FontAttributes="Bold"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"/>
                                        </Frame>

                                        <VerticalStackLayout Spacing="6"
                                                             VerticalOptions="Center"
                                                             HorizontalOptions="FillAndExpand">
                                            <Label Text="{Binding NikAvtor, FallbackValue='Название группы'}"
                                                   TextColor="White"
                                                   FontSize="20"
                                                   FontAttributes="Bold"
                                                   LineBreakMode="TailTruncation"/>
                                            <HorizontalStackLayout Spacing="6">
                                                <Label Text="ID:" TextColor="#8E8E93" FontSize="12"/>
                                                <Label Text="{Binding Id, StringFormat='#{0}', FallbackValue='#—'}"
                                                       TextColor="#0A84FF"
                                                       FontSize="12"/>
                                            </HorizontalStackLayout>
                                        </VerticalStackLayout>

                                    </HorizontalStackLayout>

                                    <!-- ИСПРАВЛЕНО: IsNotNullOrEmptyConverter теперь зарегистрирован в App.xaml -->
                                    <Frame BackgroundColor="#2C2C2E"
                                           CornerRadius="12"
                                           Padding="14"
                                           Margin="0,5,0,0"
                                           IsVisible="{Binding Description,
                                                       Converter={StaticResource IsNotNullOrEmptyConverter}}">
                                        <Label Text="{Binding Description}"
                                               TextColor="#E5E5EA"
                                               FontSize="13"
                                               LineBreakMode="WordWrap"/>
                                    </Frame>

                                    <BoxView HeightRequest="1" BackgroundColor="#2C2C2E" Margin="0,5"/>

                                    <Button Text="ПЕРЕЙТИ В ГРУППУ"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                      Path=BindingContext.PerexodCommand}"
                                            CommandParameter="{Binding .}"
                                            Background="#0A84FF"
                                            TextColor="White"
                                            FontSize="14"
                                            FontAttributes="Bold"
                                            CharacterSpacing="1"
                                            CornerRadius="14"
                                            HeightRequest="50"
                                            HorizontalOptions="FillAndExpand">
                                        <Button.Shadow>
                                            <Shadow Brush="#0A84FF" Offset="0,4" Radius="10" Opacity="0.4"/>
                                        </Button.Shadow>
                                    </Button>

                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>