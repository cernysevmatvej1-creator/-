<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Group.NewGroup"
             Title="Создание группы"
             BackgroundColor="#0D0D0D">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <!-- Заголовок страницы -->
            <VerticalStackLayout Spacing="8" Margin="0,0,0,10">
                <Label Text="НОВАЯ ГРУППА" 
                       TextColor="#8E8E93" 
                       FontSize="13" 
                       FontAttributes="Bold"
                       CharacterSpacing="2"
                       HorizontalTextAlignment="Center"/>
                <Label Text="Создайте свою группу и пригласите участников" 
                       TextColor="#636366" 
                       FontSize="13" 
                       HorizontalTextAlignment="Center"
                       Margin="0,0,0,5"/>
            </VerticalStackLayout>

            <!-- Карточка с аватаркой и основной информацией -->
            <Frame BackgroundColor="#1C1C1E" 
                   CornerRadius="20" 
                   Padding="24" 
                   HasShadow="True"
                   BorderColor="#2C2C2E">

                <VerticalStackLayout Spacing="20">

                    <!-- Аватар группы (превью) -->
                    <VerticalStackLayout Spacing="12" HorizontalOptions="Center">
                        <Frame CornerRadius="40" 
                               HeightRequest="80" 
                               WidthRequest="80" 
                               Padding="0" 
                               BackgroundColor="#BF5AF2" 
                               BorderColor="Transparent"
                               HorizontalOptions="Center">
                            <Label Text="{Binding Nik, StringFormat='{}{0:0:1}', FallbackValue='G'}" 
                                   TextColor="White" 
                                   FontSize="36" 
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center" 
                                   VerticalOptions="Center"/>
                        </Frame>
                        <Label Text="Аватар группы" 
                               TextColor="#8E8E93" 
                               FontSize="12"
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>

                    <!-- Разделитель -->
                    <BoxView HeightRequest="1" BackgroundColor="#2C2C2E" Margin="0,5"/>

                    <!-- Поле ввода: Название группы -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="НАЗВАНИЕ ГРУППЫ" 
                               TextColor="#8E8E93" 
                               FontSize="11" 
                               CharacterSpacing="1.2"/>

                        <Frame BackgroundColor="#2C2C2E" 
                               CornerRadius="12" 
                               Padding="15,5" 
                               BorderColor="#3A3A3C"
                               HasShadow="False">
                            <Entry Placeholder="Введите название" 
                                   PlaceholderColor="#636366"
                                   Text="{Binding Nik}" 
                                   TextColor="White"
                                   FontSize="16"
                                   BackgroundColor="Transparent"/>
                        </Frame>
                    </VerticalStackLayout>

                    <!-- Поле ввода: Описание -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="ОПИСАНИЕ" 
                               TextColor="#8E8E93" 
                               FontSize="11" 
                               CharacterSpacing="1.2"/>

                        <Frame BackgroundColor="#2C2C2E" 
                               CornerRadius="12" 
                               Padding="15,5" 
                               BorderColor="#3A3A3C"
                               HasShadow="False">
                            <Editor Placeholder="Расскажите о вашей группе..." 
                                    PlaceholderColor="#636366"
                                    Text="{Binding Description}" 
                                    TextColor="White"
                                    FontSize="15"
                                    BackgroundColor="Transparent"
                                    HeightRequest="100"
                                    AutoSize="TextChanges"/>
                        </Frame>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Frame>

            <!-- Карточка с дополнительной информацией -->
            <Frame BackgroundColor="#1C1C1E" 
                   CornerRadius="20" 
                   Padding="20" 
                   HasShadow="True"
                   BorderColor="#2C2C2E">

                <VerticalStackLayout Spacing="15">

                    <Label Text="ИНФОРМАЦИЯ" 
                           TextColor="#8E8E93" 
                           FontSize="12" 
                           FontAttributes="Bold"
                           CharacterSpacing="1.5"/>

                    <!-- Подсказки -->
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="✓" TextColor="#30D158" FontSize="14" VerticalTextAlignment="Start"/>
                        <Label Text="Название группы будет видно всем участникам" 
                               TextColor="#98989E" 
                               FontSize="13"
                               LineBreakMode="WordWrap"/>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="10">
                        <Label Text="✓" TextColor="#30D158" FontSize="14" VerticalTextAlignment="Start"/>
                        <Label Text="Вы сможете изменить описание в любое время" 
                               TextColor="#98989E" 
                               FontSize="13"
                               LineBreakMode="WordWrap"/>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="10">
                        <Label Text="✓" TextColor="#30D158" FontSize="14" VerticalTextAlignment="Start"/>
                        <Label Text="После создания вы станете администратором группы" 
                               TextColor="#98989E" 
                               FontSize="13"
                               LineBreakMode="WordWrap"/>
                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </Frame>

            <!-- Кнопка создания -->
            <Button Text="СОЗДАТЬ ГРУППУ" 
                    Command="{Binding SaveCommand}" 
                    Background="#30D158" 
                    TextColor="White"
                    FontSize="16"
                    FontAttributes="Bold"
                    CornerRadius="14"
                    HeightRequest="55"
                    Margin="0,10,0,20">
                <Button.Shadow>
                    <Shadow Brush="#30D158" 
                            Offset="0,4" 
                            Radius="12" 
                            Opacity="0.4"/>
                </Button.Shadow>
            </Button>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>