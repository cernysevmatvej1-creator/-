<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Group.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Group"
    Title="Group"
    x:Name="shell">

    
    <TabBar>
        
        <ShellContent
            Title="Главная"
            Icon="home.png"
            ContentTemplate="{DataTemplate local:MainPage}"
            Route="MainPage" />


        <ShellContent
            Title="Создать"
            Icon="add.png"
            ContentTemplate="{DataTemplate local:NewGroup}"
            Route="NewGroup" />
        <ShellContent
        Title="Группы"
        Icon="add.png"
        ContentTemplate="{DataTemplate local:LoadedGroup}"
        Route="LoadedGroup" />
        <ShellContent
   Title="Search"
   Icon="add.png"
   ContentTemplate="{DataTemplate local:SearhPage}"
   Route="SearhPage" />
    </TabBar>

</Shell>