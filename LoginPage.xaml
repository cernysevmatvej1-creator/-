<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Group.LoginPage"
             Title="Вход"
             BackgroundColor="#0D0D0D">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="24" VerticalOptions="Center">

            <!-- Логотип и заголовок -->
            <VerticalStackLayout Spacing="8" Margin="0,0,0,20">

                <!-- Аватар-заглушка -->
                <Frame CornerRadius="40" 
                       HeightRequest="80" 
                       WidthRequest="80" 
                       Padding="0" 
                       BackgroundColor="#0A84FF" 
                       BorderColor="Transparent"
                       HorizontalOptions="Center"
                       Margin="0,0,0,10">
                    <Label Text="G" 
                           TextColor="White" 
                           FontSize="36" 
                           FontAttributes="Bold"
                           HorizontalOptions="Center" 
                           VerticalOptions="Center"/>
                </Frame>

                <Label Text="ДОБРО ПОЖАЛОВАТЬ" 
                       TextColor="#8E8E93" 
                       FontSize="12" 
                       FontAttributes="Bold"
                       CharacterSpacing="2"
                       HorizontalTextAlignment="Center"/>

                <Label Text="Войдите в приложение" 
                       TextColor="#E5E5EA" 
                       FontSize="24" 
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center"/>

                <Label Text="Введите ваш никнейм чтобы продолжить" 
                       TextColor="#636366" 
                       FontSize="13"
                       HorizontalTextAlignment="Center"
                       Margin="0,5,0,0"/>

            </VerticalStackLayout>

            <!-- Карточка с формой входа -->
            <Frame BackgroundColor="#1C1C1E" 
                   CornerRadius="20" 
                   Padding="20" 
                   HasShadow="True"
                   BorderColor="#2C2C2E">

                <VerticalStackLayout Spacing="20">

                    <!-- Поле ввода ника -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="ВАШ НИКНЕЙМ" 
                               TextColor="#8E8E93" 
                               FontSize="11" 
                               CharacterSpacing="1.2"/>

                        <Frame BackgroundColor="#2C2C2E" 
                               CornerRadius="14" 
                               Padding="15,5" 
                               BorderColor="#3A3A3C"
                               HasShadow="False">
                            <Entry Placeholder="Введите ваш ник" 
                                   PlaceholderColor="#636366"
                                   Text="{Binding Nik}" 
                                   TextColor="White"
                                   FontSize="16"
                                   BackgroundColor="Transparent"/>
                        </Frame>
                    </VerticalStackLayout>

                    <!-- Политика конфиденциальности -->
                    <Frame BackgroundColor="#2C2C2E" 
                           CornerRadius="12" 
                           Padding="14"
                           HasShadow="False">

                        <HorizontalStackLayout Spacing="10">
                            <CheckBox IsChecked="{Binding Ischekedbutton}" 
                                      Color="#0A84FF">
                                <CheckBox.Shadow>
                                    <Shadow Brush="#0A84FF" 
                                            Offset="0,0" 
                                            Radius="6" 
                                            Opacity="0.3"/>
                                </CheckBox.Shadow>
                            </CheckBox>

                            <VerticalStackLayout Spacing="4" HorizontalOptions="FillAndExpand" VerticalOptions="Center">
                                <Label Text="ПОЛИТИКА КОНФИДЕНЦИАЛЬНОСТИ" 
                                       TextColor="#8E8E93" 
                                       FontSize="11" 
                                       CharacterSpacing="1"/>
                                <Label Text="Я принимаю условия использования и политику конфиденциальности" 
                                       TextColor="#E5E5EA" 
                                       FontSize="12"
                                       LineBreakMode="WordWrap"/>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>

                    </Frame>

                    <!-- Кнопка входа -->
                    <Button Text="ВОЙТИ" 
                            Command="{Binding SignAnonimalCommand}" 
                            Background="#30D158" 
                            TextColor="White"
                            FontSize="16"
                            FontAttributes="Bold"
                            CharacterSpacing="1.5"
                            CornerRadius="14"
                            HeightRequest="55"
                            Margin="0,5,0,0"
                            IsEnabled="{Binding Ischekedbutton}">
                        <Button.Shadow>
                            <Shadow Brush="#30D158" 
                                    Offset="0,4" 
                                    Radius="12" 
                                    Opacity="0.4"/>
                        </Button.Shadow>
                    </Button>

                </VerticalStackLayout>

            </Frame>

            <!-- Индикатор загрузки -->
         

            <!-- Дополнительная информация -->
            <Label Text="Нажимая кнопку Войти, вы соглашаетесь с условиями" 
                   TextColor="#636366" 
                   FontSize="11" 
                   HorizontalTextAlignment="Center"
                   Margin="0,10,0,0"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>