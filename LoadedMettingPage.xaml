<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Group.LoadedMettingPage"
             xmlns:local="clr-namespace:Group.Models"
             Title="Встречи"
             BackgroundColor="#0D0D0D">

    <!-- УБРАН ContentPage.Resources — конвертеры теперь в App.xaml -->

    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="16">

            <VerticalStackLayout Spacing="6" Margin="0,0,0,8">
                <Label Text="ВСТРЕЧИ ГРУППЫ"
                       TextColor="#8E8E93"
                       FontSize="13"
                       FontAttributes="Bold"
                       CharacterSpacing="2"/>
                <HorizontalStackLayout Spacing="6">
                    <Label Text="Всего встреч:" TextColor="#636366" FontSize="13"/>
                    <Label Text="{Binding Metting.Count}"
                           TextColor="#0A84FF"
                           FontSize="13"
                           FontAttributes="Bold"/>
                </HorizontalStackLayout>
                <BoxView HeightRequest="1" BackgroundColor="#2C2C2E" Margin="0,8"/>
            </VerticalStackLayout>

            <CollectionView ItemsSource="{Binding Metting}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="local:Metting">
                        <Frame BackgroundColor="#1C1C1E"
                               CornerRadius="20"
                               Padding="18"
                               Margin="0,0,0,16"
                               HasShadow="True"
                               BorderColor="#2C2C2E">
                            <VerticalStackLayout Spacing="16">

                                <!-- Автор -->
                                <HorizontalStackLayout Spacing="12">
                                    <Frame CornerRadius="22"
                                           HeightRequest="44"
                                           WidthRequest="44"
                                           Padding="0"
                                           BackgroundColor="#BF5AF2"
                                           BorderColor="Transparent">
                                        <!-- ИСПРАВЛЕНО: FirstCharConverter вместо '{}{0:0:1}' -->
                                        <Label Text="{Binding NameAvtorMetting,
                                                       Converter={StaticResource FirstCharConverter},
                                                       FallbackValue='A'}"
                                               TextColor="White"
                                               FontSize="18"
                                               FontAttributes="Bold"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"/>
                                    </Frame>
                                    <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                                        <Label Text="ОРГАНИЗАТОР"
                                               TextColor="#8E8E93"
                                               FontSize="10"
                                               CharacterSpacing="1.2"/>
                                        <Label Text="{Binding NameAvtorMetting, FallbackValue='Имя организатора'}"
                                               TextColor="White"
                                               FontSize="16"
                                               FontAttributes="Bold"
                                               LineBreakMode="TailTruncation"/>
                                    </VerticalStackLayout>
                                </HorizontalStackLayout>

                                <BoxView HeightRequest="1" BackgroundColor="#2C2C2E"/>

                                <!-- Место и время -->
                                <VerticalStackLayout Spacing="12">
                                    <HorizontalStackLayout Spacing="12">
                                        <Frame BackgroundColor="#2C2C2E" CornerRadius="10" Padding="8"
                                               WidthRequest="36" HeightRequest="36">
                                            <Label Text="📍" FontSize="16"
                                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                                        </Frame>
                                        <VerticalStackLayout Spacing="2" HorizontalOptions="FillAndExpand" VerticalOptions="Center">
                                            <Label Text="МЕСТО ВСТРЕЧИ" TextColor="#8E8E93" FontSize="10" CharacterSpacing="1"/>
                                            <Label Text="{Binding Mesto, FallbackValue='Не указано'}"
                                                   TextColor="White" FontSize="15" LineBreakMode="WordWrap"/>
                                        </VerticalStackLayout>
                                    </HorizontalStackLayout>

                                    <HorizontalStackLayout Spacing="12">
                                        <Frame BackgroundColor="#2C2C2E" CornerRadius="10" Padding="8"
                                               WidthRequest="36" HeightRequest="36">
                                            <Label Text="📅" FontSize="16"
                                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                                        </Frame>
                                        <VerticalStackLayout Spacing="2" HorizontalOptions="FillAndExpand" VerticalOptions="Center">
                                            <Label Text="ДАТА И ВРЕМЯ" TextColor="#8E8E93" FontSize="10" CharacterSpacing="1"/>
                                            <Label Text="{Binding Time, FallbackValue='Не указано'}"
                                                   TextColor="White" FontSize="15"/>
                                        </VerticalStackLayout>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>

                                <BoxView HeightRequest="1" BackgroundColor="#2C2C2E"/>

                                <!-- Кнопки -->
                                <HorizontalStackLayout Spacing="10" HorizontalOptions="FillAndExpand">
                                    <Button Text="✓ ПОЙДУ"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                      Path=BindingContext.PoitiCommand}"
                                            CommandParameter="{Binding .}"
                                            Background="#30D158" TextColor="White"
                                            FontSize="13" FontAttributes="Bold" CharacterSpacing="1"
                                            CornerRadius="12" HeightRequest="45"
                                            HorizontalOptions="FillAndExpand">
                                        <Button.Shadow>
                                            <Shadow Brush="#30D158" Offset="0,3" Radius="8" Opacity="0.4"/>
                                        </Button.Shadow>
                                    </Button>
                                    <Button Text="✗ НЕ ПОЙДУ"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}},
                                                      Path=BindingContext.NoPoitiCommand}"
                                            CommandParameter="{Binding .}"
                                            Background="#FF453A" TextColor="White"
                                            FontSize="13" FontAttributes="Bold" CharacterSpacing="1"
                                            CornerRadius="12" HeightRequest="45"
                                            HorizontalOptions="FillAndExpand">
                                        <Button.Shadow>
                                            <Shadow Brush="#FF453A" Offset="0,3" Radius="8" Opacity="0.4"/>
                                        </Button.Shadow>
                                    </Button>
                                </HorizontalStackLayout>

                                <!-- Участники — видны если есть -->
                                <VerticalStackLayout Spacing="10"
                                                     IsVisible="{Binding Users.Count,
                                                                 Converter={StaticResource IntToBoolConverter}}">
                                    <HorizontalStackLayout Spacing="8" Margin="0,5,0,0">
                                        <Label Text="👥" FontSize="14"/>
                                        <Label Text="УЧАСТНИКИ" TextColor="#8E8E93" FontSize="11" CharacterSpacing="1.2"/>
                                        <Label Text="{Binding Users.Count, StringFormat='({0})'}"
                                               TextColor="#636366" FontSize="11"/>
                                    </HorizontalStackLayout>

                                    <CollectionView ItemsSource="{Binding Users}" HeightRequest="150">
                                        <CollectionView.ItemTemplate>
                                            <!-- ИСПРАВЛЕНО: был local:User — правильно local:WhoWillGo -->
                                            <DataTemplate x:DataType="local:WhoWillGo">
                                                <Frame BackgroundColor="#2C2C2E"
                                                       CornerRadius="12"
                                                       Padding="12,8"
                                                       Margin="0,0,0,6">
                                                    <HorizontalStackLayout Spacing="10">

                                                        <Frame CornerRadius="15"
                                                               HeightRequest="30" WidthRequest="30"
                                                               Padding="0"
                                                               BackgroundColor="#5E5CE6"
                                                               BorderColor="Transparent">
                                                            <!-- ИСПРАВЛЕНО: FirstCharConverter -->
                                                            <Label Text="{Binding User.Name,
                                                                           Converter={StaticResource FirstCharConverter},
                                                                           FallbackValue='U'}"
                                                                   TextColor="White" FontSize="12" FontAttributes="Bold"
                                                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                                                        </Frame>

                                                        <VerticalStackLayout Spacing="2" HorizontalOptions="FillAndExpand">
                                                            <Label Text="{Binding User.Name, FallbackValue='Участник'}"
                                                                   TextColor="White" FontSize="14" FontAttributes="Bold"
                                                                   LineBreakMode="TailTruncation"/>
                                                            <Label Text="{Binding User.Id, StringFormat='ID: {0}'}"
                                                                   TextColor="#8E8E93" FontSize="10"/>
                                                        </VerticalStackLayout>

                                                        <Frame BackgroundColor="{Binding IfGo,
                                                                                 Converter={StaticResource StatusToColorConverter}}"
                                                               CornerRadius="12" Padding="10,4"
                                                               HorizontalOptions="End" VerticalOptions="Center">
                                                            <Label Text="{Binding IfGo,
                                                                           Converter={StaticResource StatusToTextConverter}}"
                                                                   TextColor="White" FontSize="10"
                                                                   FontAttributes="Bold" CharacterSpacing="0.5"/>
                                                        </Frame>

                                                    </HorizontalStackLayout>
                                                </Frame>
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>
                                </VerticalStackLayout>

                                <!-- Если участников нет -->
                                <Frame BackgroundColor="#2C2C2E"
                                       CornerRadius="12"
                                       Padding="15"
                                       IsVisible="{Binding Users.Count,
                                                   Converter={StaticResource InverseIntToBoolConverter}}">
                                    <Label Text="Пока никто не отметился"
                                           TextColor="#8E8E93"
                                           FontSize="13"
                                           HorizontalTextAlignment="Center"/>
                                </Frame>

                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Если встреч нет -->
            <VerticalStackLayout Spacing="20"
                                 IsVisible="{Binding Metting.Count,
                                             Converter={StaticResource InverseIntToBoolConverter}}"
                                 Padding="30,40">
                <Frame BackgroundColor="#1C1C1E" CornerRadius="20" Padding="30">
                    <VerticalStackLayout Spacing="16">
                        <Label Text="📅" FontSize="48" HorizontalTextAlignment="Center"/>
                        <Label Text="ВСТРЕЧ ПОКА НЕТ"
                               TextColor="#8E8E93" FontSize="14" FontAttributes="Bold"
                               CharacterSpacing="1.5" HorizontalTextAlignment="Center"/>
                        <Label Text="Здесь будут отображаться встречи, организованные участниками группы"
                               TextColor="#636366" FontSize="13"
                               HorizontalTextAlignment="Center" LineBreakMode="WordWrap"/>
                    </VerticalStackLayout>
                </Frame>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>