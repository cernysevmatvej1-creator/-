<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Group.ChatGroup"
             xmlns:local="clr-namespace:Group.Models"
             xmlns:viewmodel="clr-namespace:Group.ViewModel"
             Title="Чат"
             BackgroundColor="#0D0D0D"
             NavigationPage.HasBackButton="True">

    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Шапка чата -->
        <Grid Grid.Row="0" 
              BackgroundColor="#1C1C1E" 
              HeightRequest="50" 
              VerticalOptions="Start"
              IsVisible="False">
            <!-- Скрываем, но оставляем для будущих улучшений -->
        </Grid>

        <!-- Область сообщений -->
        <CollectionView Grid.Row="0"
                        x:Name="MessagesCollectionView"
                        ItemsSource="{Binding Messages}"
                        SelectionMode="None"
                        Margin="12,10,12,5"
                        VerticalScrollBarVisibility="Always"
                        ItemsUpdatingScrollMode="KeepScrollOffset">

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="local:Message">

                    <SwipeView>
                        <!-- Правая сторона (смахивание влево) - Действия -->
                        <SwipeView.RightItems>
                            <SwipeItems Mode="Reveal">

                                <!-- Кнопка ответа -->
                                <SwipeItem Text="↩️"
                                           BackgroundColor="#0A84FF"
                                           Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:ChatGroupViewModel}}, Path=ReplyMessageCommand}"
                                           CommandParameter="{Binding .}">

                                </SwipeItem>

                                <!-- Кнопка копирования -->
                                <SwipeItem Text="📋"
                                           BackgroundColor="#5E5CE6"
                                           Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:ChatGroupViewModel}}, Path=CopyMessageCommand}"
                                           CommandParameter="{Binding .}"/>

                                <!-- Кнопка удаления -->
                                <SwipeItem Text="🗑️"
                                           BackgroundColor="#FF453A"
                                           Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:ChatGroupViewModel}}, Path=DeleteMessageCommand}"
                                           CommandParameter="{Binding .}">
                                   
                                </SwipeItem>

                            </SwipeItems>
                        </SwipeView.RightItems>

                        <!-- Левая сторона (смахивание вправо) - Пересылка -->
                        <SwipeView.LeftItems>
                            <SwipeItems Mode="Reveal">

                                <SwipeItem Text="➡️"
                                           BackgroundColor="#30D158"
                                           Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:ChatGroupViewModel}}, Path=ForwardMessageCommand}"
                                           CommandParameter="{Binding .}">
                                 
                                </SwipeItem>

                            </SwipeItems>
                        </SwipeView.LeftItems>

                        <!-- Содержимое сообщения -->
                        <Grid Padding="0" Margin="0,6,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Аватар пользователя (слева) -->
                            <Frame Grid.Column="0"
                                   CornerRadius="20"
                                   HeightRequest="36"
                                   WidthRequest="36"
                                   Padding="0"
                                   BackgroundColor="#BF5AF2"
                                   BorderColor="Transparent"
                                   HorizontalOptions="Start"
                                   VerticalOptions="Start"
                                   Margin="0,0,8,0">
                                <Label Text="{Binding Name, StringFormat='{}{0:0:1}'}"
                                       TextColor="White"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Frame>

                            <!-- Блок сообщения -->
                            <Frame Grid.Column="1"
                                   BackgroundColor="#1C1C1E"
                                   CornerRadius="16"
                                   Padding="14,10"
                                   MaximumWidthRequest="260"
                                   HasShadow="True"
                                   BorderColor="#2C2C2E">

                                <VerticalStackLayout Spacing="6">

                                    <!-- Имя отправителя и время в одной строке -->
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="{Binding Name}"
                                               TextColor="#0A84FF"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               LineBreakMode="TailTruncation"/>

                                        <Label Text="{Binding Time, StringFormat='{0:HH:mm}'}"
                                               TextColor="#636366"
                                               FontSize="11"
                                               VerticalTextAlignment="Center"
                                               HorizontalOptions="EndAndExpand"/>
                                    </HorizontalStackLayout>

                                    <!-- Текст сообщения -->
                                    <Label Text="{Binding Messag}"
                                           TextColor="#E5E5EA"
                                           FontSize="15"
                                           LineBreakMode="WordWrap"
                                           Margin="0,2,0,0"/>

                                </VerticalStackLayout>
                            </Frame>
                        </Grid>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Индикатор ответа (появляется при reply) -->
        <Frame Grid.Row="0"
               BackgroundColor="#1C1C1E"
               BorderColor="#0A84FF"
               CornerRadius="12"
               Padding="12,8"
               Margin="12,10,12,0"
               VerticalOptions="Start"
               HasShadow="True"
               IsVisible="{Binding IsReplying, FallbackValue=False}">

            <HorizontalStackLayout Spacing="8">
                <Label Text="↩️" FontSize="16" VerticalTextAlignment="Center"/>
                <VerticalStackLayout Spacing="2" HorizontalOptions="FillAndExpand">
                    <Label Text="Ответ на:" 
                           TextColor="#8E8E93" 
                           FontSize="10" 
                           CharacterSpacing="1"/>
                    <Label Text="{Binding ReplyToMessagePreview}" 
                           TextColor="#E5E5EA" 
                           FontSize="13"
                           LineBreakMode="TailTruncation"/>
                </VerticalStackLayout>
                <Button Text="✕" 
                        BackgroundColor="Transparent" 
                        TextColor="#8E8E93"
                        FontSize="16"
                        WidthRequest="30"
                        HeightRequest="30"
                        CornerRadius="15"
                        Command="{Binding CancelReplyCommand}"/>
            </HorizontalStackLayout>
        </Frame>

        <!-- Панель ввода сообщения -->
        <Grid Grid.Row="1"
              BackgroundColor="#1C1C1E"
              Padding="12,10"
              ColumnSpacing="10">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Поле ввода -->
            <Frame Grid.Column="0"
                   BackgroundColor="#2C2C2E"
                   CornerRadius="20"
                   Padding="16,0"
                   BorderColor="#3A3A3C"
                   HasShadow="False">

                <Entry Placeholder="Написать сообщение..."
                       PlaceholderColor="#636366"
                       Text="{Binding Messags}"
                       TextColor="White"
                       FontSize="15"
                       BackgroundColor="Transparent"
                       HeightRequest="42"
                       VerticalOptions="Center"/>
            </Frame>

            <!-- Кнопка отправки -->
            <Button Grid.Column="1"
                    Text="➤"
                    BackgroundColor="#0A84FF"
                    TextColor="White"
                    FontSize="18"
                    WidthRequest="44"
                    HeightRequest="44"
                    CornerRadius="22"
                    Command="{Binding AddMessageCommand}">
                <Button.Shadow>
                    <Shadow Brush="#0A84FF" 
                            Offset="0,3" 
                            Radius="8" 
                            Opacity="0.3"/>
                </Button.Shadow>
            </Button>

        </Grid>
    </Grid>
</ContentPage>