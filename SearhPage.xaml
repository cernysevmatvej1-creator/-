<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Group.SearhPage"
             xmlns:local="clr-namespace:Group.Models"
             Title="Поиск групп"
             BackgroundColor="#0D0D0D">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="20">

            <!-- Заголовок страницы -->
            <VerticalStackLayout Spacing="6" Margin="0,0,0,8">
                <Label Text="ПОИСК ГРУПП"
                       TextColor="#8E8E93"
                       FontSize="13"
                       FontAttributes="Bold"
                       CharacterSpacing="2"/>
                <Label Text="Найдите группу по ID и присоединитесь"
                       TextColor="#636366"
                       FontSize="13"/>
                <BoxView HeightRequest="1" BackgroundColor="#2C2C2E" Margin="0,8"/>
            </VerticalStackLayout>

            <!-- Карточка поиска -->
            <Frame BackgroundColor="#1C1C1E"
                   CornerRadius="20"
                   Padding="20"
                   HasShadow="True"
                   BorderColor="#2C2C2E">
                <VerticalStackLayout Spacing="16">

                    <HorizontalStackLayout Spacing="8">
                        <Label Text="🔍" FontSize="16"/>
                        <Label Text="ПОИСК ПО ID"
                               TextColor="#8E8E93"
                               FontSize="13"
                               FontAttributes="Bold"
                               CharacterSpacing="1.5"/>
                    </HorizontalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="ВВЕДИТЕ ID ГРУППЫ"
                               TextColor="#8E8E93"
                               FontSize="11"
                               CharacterSpacing="1.2"/>
                        <Frame BackgroundColor="#2C2C2E"
                               CornerRadius="14"
                               Padding="15,5"
                               BorderColor="#3A3A3C"
                               HasShadow="False">
                            <Entry Placeholder="Например: 12345"
                                   PlaceholderColor="#636366"
                                   Text="{Binding GroupId}"
                                   TextColor="White"
                                   FontSize="16"
                                   Keyboard="Numeric"
                                   BackgroundColor="Transparent"/>
                        </Frame>
                    </VerticalStackLayout>

                    <Button Text="🔍 НАЙТИ ГРУППУ"
                            Command="{Binding SearchGroupCommand}"
                            Background="#0A84FF"
                            TextColor="White"
                            FontSize="15"
                            FontAttributes="Bold"
                            CharacterSpacing="1"
                            CornerRadius="14"
                            HeightRequest="50"
                            Margin="0,5,0,0">
                        <Button.Shadow>
                            <Shadow Brush="#0A84FF" Offset="0,4" Radius="10" Opacity="0.4"/>
                        </Button.Shadow>
                    </Button>

                </VerticalStackLayout>
            </Frame>

            <!-- Результаты поиска — видны только когда есть данные -->
            <VerticalStackLayout Spacing="12"
                                 IsVisible="{Binding Groups.Count,
                                             Converter={StaticResource IntToBoolConverter}}">

                <HorizontalStackLayout Spacing="6" Margin="0,10,0,5">
                    <Label Text="📋" FontSize="14"/>
                    <Label Text="РЕЗУЛЬТАТЫ ПОИСКА"
                           TextColor="#8E8E93"
                           FontSize="12"
                           FontAttributes="Bold"
                           CharacterSpacing="1.5"/>
                    <Label Text="{Binding Groups.Count, StringFormat='({0})'}"
                           TextColor="#0A84FF"
                           FontSize="12"
                           FontAttributes="Bold"/>
                </HorizontalStackLayout>

                <CollectionView ItemsSource="{Binding Groups}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="local:NewGroupModel">
                            <Frame BackgroundColor="#1C1C1E"
                                   CornerRadius="16"
                                   Padding="16"
                                   Margin="0,0,0,12"
                                   HasShadow="True"
                                   BorderColor="#2C2C2E">
                                <VerticalStackLayout Spacing="14">

                                    <HorizontalStackLayout Spacing="12">

                                        <!-- Аватар — исправлен конвертер первой буквы -->
                                        <Frame CornerRadius="25"
                                               HeightRequest="50"
                                               WidthRequest="50"
                                               Padding="0"
                                               BackgroundColor="#BF5AF2"
                                               BorderColor="Transparent">
                                            <Label Text="{Binding NikAvtor,
                                                           Converter={StaticResource FirstCharConverter},
                                                           FallbackValue='G'}"
                                                   TextColor="White"
                                                   FontSize="22"
                                                   FontAttributes="Bold"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"/>
                                        </Frame>

                                        <VerticalStackLayout Spacing="4"
                                                             VerticalOptions="Center"
                                                             HorizontalOptions="FillAndExpand">
                                            <Label Text="{Binding NikAvtor, FallbackValue='Название группы'}"
                                                   TextColor="White"
                                                   FontSize="18"
                                                   FontAttributes="Bold"
                                                   LineBreakMode="TailTruncation"/>
                                            <HorizontalStackLayout Spacing="6">
                                                <Label Text="ID:" TextColor="#8E8E93" FontSize="11"/>
                                                <Label Text="{Binding Id, StringFormat='#{0}'}"
                                                       TextColor="#0A84FF"
                                                       FontSize="11"/>
                                            </HorizontalStackLayout>
                                        </VerticalStackLayout>

                                    </HorizontalStackLayout>

                                    <!-- Описание — видно только если не пустое -->
                                    <Frame BackgroundColor="#2C2C2E"
                                           CornerRadius="10"
                                           Padding="12"
                                           IsVisible="{Binding Description,
                                                       Converter={StaticResource IsNotNullOrEmptyConverter}}">
                                        <Label Text="{Binding Description}"
                                               TextColor="#E5E5EA"
                                               FontSize="12"
                                               LineBreakMode="WordWrap"/>
                                    </Frame>

                                    <BoxView HeightRequest="1" BackgroundColor="#2C2C2E" Margin="0,5"/>

                                    <!-- Кнопка заявки — команда из родительской страницы -->
                                    <Button Text="📝 ПОДАТЬ ЗАЯВКУ"
                                            Command="{Binding BindingContext.AddBidCommand,
                                                      Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                            CommandParameter="{Binding .}"
                                            Background="#30D158"
                                            TextColor="White"
                                            FontSize="14"
                                            FontAttributes="Bold"
                                            CharacterSpacing="1"
                                            CornerRadius="12"
                                            HeightRequest="45"
                                            HorizontalOptions="FillAndExpand">
                                        <Button.Shadow>
                                            <Shadow Brush="#30D158" Offset="0,3" Radius="8" Opacity="0.4"/>
                                        </Button.Shadow>
                                    </Button>

                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>

            <!-- Подсказка внизу -->
            <Frame BackgroundColor="#2C2C2E"
                   CornerRadius="12"
                   Padding="16"
                   Margin="0,10,0,0">
                <HorizontalStackLayout Spacing="10">
                    <Label Text="💡" FontSize="16" VerticalTextAlignment="Center"/>
                    <Label Text="Введите ID группы, чтобы найти её и отправить заявку на вступление"
                           TextColor="#E5E5EA"
                           FontSize="12"
                           LineBreakMode="WordWrap"
                           VerticalTextAlignment="Center"/>
                </HorizontalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>